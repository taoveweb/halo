<view class="container">
  <view class="page-title">动态详情</view>

  <view wx:if="{{tweet}}" class="card">
    <view>{{tweet.authorName}} @{{tweet.authorHandle}}</view>
    <view style="margin-top: 10rpx;">{{tweet.content}}</view>
  </view>

  <view class="card">
    <view style="font-weight: 700; margin-bottom: 10rpx;">评论</view>
    <view wx:for="{{comments}}" wx:key="id" style="margin-bottom: 12rpx;">
      <view>{{item.authorName}}：{{item.content}}</view>
      <view class="muted">{{item.createdAtLabel}}</view>
    </view>
  </view>

  <input class="input" placeholder="写评论..." value="{{content}}" bindinput="onInput" />
  <button class="btn" bindtap="comment">发送评论</button>
</view>
