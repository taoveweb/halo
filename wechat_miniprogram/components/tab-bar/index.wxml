<view class="tab-bar-safe-area">
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{current === item.key ? 'active' : ''}}"
      data-path="{{item.pagePath}}"
      bindtap="switchTab"
    >
      <view class="tab-icon">{{item.icon}}</view>
      <view class="tab-text">{{item.text}}</view>
    </view>
  </view>
</view>
