page {
  min-height: 100vh;
  background: #000;
  color: #fff;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #111;
  border: 1rpx solid #222;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.input,
.textarea {
  width: 100%;
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 16rpx;
  color: #fff;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 180rpx;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #1d9bf0;
  color: #fff;
  border-radius: 999rpx;
  padding: 14rpx 28rpx;
  font-size: 28rpx;
  border: none;
}

.btn-secondary {
  background: transparent;
  border: 1rpx solid #555;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.muted {
  color: #71767b;
  font-size: 24rpx;
}
